{
  "name": "discord.ts-template",
  "version": "1.0.0",
  "description": "A template on TypeScript that uses discord.js and discordx libraries for creating Discord bots.",
  "main": "index.js",
  "scripts": {
    "build": "tsc && resolve-tspaths",
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch build/ -r tsconfig-paths/register source/index.ts",
    "start": "node build/index.js"
  },
  "author": "Maurício Braz Gonçalves <https://github.com/mauriciobraz>",
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/node": "^17.0.35",
    "resolve-tspaths": "^0.5.0",
    "ts-node-dev": "^1.1.8",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^4.6.4"
  },
  "dependencies": {
    "discord.js": "^13.7.0",
    "discordx": "^9.7.0",
    "dotenv": "^16.0.1",
    "glob": "^8.0.3",
    "tslib": "^2.4.0"
  }
}
